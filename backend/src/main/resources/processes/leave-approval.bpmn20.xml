<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://www.flowable.org/process">

    <process id="leave-approval" name="请假审批流程" isExecutable="true">
        <documentation>员工请假申请 → 直接主管审批 → 流程结束</documentation>

        <startEvent id="startEvent" name="开始">
            <extensionElements>
                <flowable:formProperty id="leaveType" name="请假类型" type="enum" required="true">
                    <flowable:value id="annual" name="年假" />
                    <flowable:value id="sick" name="病假" />
                    <flowable:value id="personal" name="事假" />
                </flowable:formProperty>
                <flowable:formProperty id="startDate" name="开始日期" type="date" required="true" />
                <flowable:formProperty id="endDate" name="结束日期" type="date" required="true" />
                <flowable:formProperty id="reason" name="请假原因" type="string" required="true" />
            </extensionElements>
        </startEvent>

        <userTask id="managerApproval" name="主管审批" flowable:assignee="${managerId}">
            <documentation>请审批 ${applicantName} 的请假申请（${leaveType}，${startDate} 至 ${endDate}）</documentation>
            <extensionElements>
                <flowable:formProperty id="approved" name="审批意见" type="enum" required="true">
                    <flowable:value id="true" name="同意" />
                    <flowable:value id="false" name="驳回" />
                </flowable:formProperty>
                <flowable:formProperty id="comment" name="审批备注" type="string" />
            </extensionElements>
        </userTask>

        <exclusiveGateway id="gateway1" name="审批结果" />

        <endEvent id="endApproved" name="审批通过" />
        <endEvent id="endRejected" name="审批驳回" />

        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="managerApproval" />
        <sequenceFlow id="flow2" sourceRef="managerApproval" targetRef="gateway1" />
        <sequenceFlow id="flow3" sourceRef="gateway1" targetRef="endApproved">
            <conditionExpression>${approved == true}</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="flow4" sourceRef="gateway1" targetRef="endRejected">
            <conditionExpression>${approved == false}</conditionExpression>
        </sequenceFlow>
    </process>

    <bpmndi:BPMNDiagram id="BPMNDiagram_leave-approval">
        <bpmndi:BPMNPlane bpmnElement="leave-approval" id="BPMNPlane_leave-approval">
            <bpmndi:BPMNShape id="startEventShape" bpmnElement="startEvent">
                <omgdc:Bounds height="30" width="30" x="100" y="163" />
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="managerApprovalShape" bpmnElement="managerApproval">
                <omgdc:Bounds height="80" width="100" x="200" y="138" />
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="gateway1Shape" bpmnElement="gateway1" isMarkerVisible="true">
                <omgdc:Bounds height="40" width="40" x="370" y="158" />
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="endApprovedShape" bpmnElement="endApproved">
                <omgdc:Bounds height="28" width="28" x="480" y="120" />
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="endRejectedShape" bpmnElement="endRejected">
                <omgdc:Bounds height="28" width="28" x="480" y="200" />
            </bpmndi:BPMNShape>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
</definitions>
